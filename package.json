{
  "name": "newscrux-custom",
  "version": "1.0.0",
  "description": "AI news aggregator with Telegram bot control, scheduled polls, optional 3D layer, and multilingual summaries",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/faruk3d8/newscrux-custom.git"
  },
  "homepage": "https://github.com/faruk3d8/newscrux-custom#readme",
  "bugs": {
    "url": "https://github.com/faruk3d8/newscrux-custom/issues"
  },
  "keywords": [
    "ai",
    "news",
    "rss",
    "telegram",
    "summarizer",
    "multilingual",
    "raspberry-pi",
    "typescript",
    "deepseek",
    "openrouter"
  ],
  "bin": {
    "newscrux": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-build-info.mjs && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test:security": "npm run build && node scripts/test-url-security.mjs"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.1.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
