# ========================================
# Newscrux Configuration
# ========================================

# OpenRouter API Key (required)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model (default: deepseek/deepseek-v3.2-speciale)
OPENROUTER_MODEL=deepseek/deepseek-v3.2-speciale

# Telegram credentials (required)
# Bot: talk to @BotFather, chat ID: message your bot then check getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Otomatik arama saatleri ve bot komutları:
# src/telegram-commands.config.ts dosyasını düzenleyin (varsayılan: İstanbul 12:00 ve 20:00)

# Maximum articles to process per poll cycle (default: 10, Pi: 5 recommended)
MAX_ARTICLES_PER_POLL=5

# arXiv papers per poll cycle (default: 15, Pi: 8 recommended)
ARXIV_MAX_PER_POLL=8

# AI relevance filter threshold, 1-10 (default: 6, Pi: 7 recommended)
RELEVANCE_THRESHOLD=7

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
