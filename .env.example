# ========================================
# Newscrux-Custom Configuration
# ========================================

# OpenRouter API Key (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model (default: deepseek/deepseek-v3.2-speciale)
OPENROUTER_MODEL=deepseek/deepseek-v3.2-speciale

# Telegram credentials (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Otomatik arama saatleri: src/telegram-commands.config.ts (varsayılan İstanbul 12:00, 20:00)

# --- Hız / limitler (Pi için düşük tutun) ---
MAX_ARTICLES_PER_POLL=5
ARXIV_MAX_PER_POLL=8
MAX_RELEVANCE_BATCH=25
RELEVANCE_THRESHOLD=7
SUMMARIZE_DELAY_MS=2000
SEND_DELAY_MS=500
SUMMARIZE_CONCURRENCY=2

# --- Dahili hızlı mod limitleri (FAST_*; ayrı bot komutu yok) ---
FAST_MAX_ARTICLES=3
FAST_ARXIV_MAX=0
FAST_RELEVANCE_BATCH=10
FAST_SUMMARIZE_CONCURRENCY=2

# --- Kaynak profili: minimal (5 feed) | full (13 feed) ---
FEED_PROFILE=full

# --- Görünürlük / operasyon ---
# Poll ilerlemesi yalnızca log dosyasına yazılır (Telegram'a detay mesajı gitmez)
PROGRESS_HEARTBEAT_MS=120000
STARTUP_NOTIFY=true
# Poll metrik özeti Telegram'a gönderilmez (varsayılan kapalı); /status ile görülebilir
POLL_METRICS_NOTIFY=false
COMMAND_RATE_LIMIT_PER_MINUTE=10

# --- OpenRouter kredi uyarısı (USD; token değil) ---
OPENROUTER_CREDIT_ALERT=true
OPENROUTER_CREDIT_ALERT_MIN_USD=1
OPENROUTER_CREDIT_ALERT_COOLDOWN_MS=86400000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Scraping (SSRF korumalı — yalnızca http/https, özel IP yok)
SCRAPE_TIMEOUT_MS=10000
SCRAPE_DELAY_MS=2000

# ========================================
# 3D AI news layer (default: off — /3dainewsopen)
# Settings: src/threed.config.ts + THREED_* env
# ========================================
# THREED_COMMAND_STATUS=3dainews
# THREED_COMMAND_ENABLE=3dainewsopen
# THREED_COMMAND_DISABLE=3dainewsclose
# THREED_SCHEDULE_HOUR=12
# THREED_MAX_SUMMARIZE=5
# THREED_MAX_RELEVANCE_BATCH=25
# THREED_RELEVANCE_THRESHOLD=7
# THREED_MONTHLY_BUDGET_USD=2
# THREED_MONTHLY_TARGET_USD=1.5
# THREED_COST_PER_1M_PROMPT=0.14
# THREED_COST_PER_1M_COMPLETION=0.28
# THREED_CS_CV_KEYWORDS=3d,mesh,nerf,cad,...
# THREED_FEED_NVIDIA=https://blogs.nvidia.com/feed/
# THREED_FEED_STABILITY=https://stability.ai/blog/rss.xml
# THREED_FEED_BLENDER=https://www.blendernation.com/feed/
# THREED_FEED_TRIPO=https://www.tripo3d.ai/blog/rss.xml
# THREED_FEED_MESHY=https://www.meshy.ai/blog/rss.xml
